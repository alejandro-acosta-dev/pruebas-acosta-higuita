{
	"info": {
		"name": "SAFAB - AppEducativa",
		"description": "Coleccion de pruebas de API para el sistema SAFAB (Sistema Adaptativo de Funciones en Algoritmia Basica). Cubre los modulos de Login, Tipo de Pregunta (Maestra) y Pregunta (Transaccional).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
