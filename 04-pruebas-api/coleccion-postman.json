	"item": [
		{
			"name": "Login",
			"item": [
				{
					"name": "Login exitoso",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Codigo de respuesta es 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"La respuesta contiene token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"});",
									"pm.test(\"La respuesta contiene el nombre del usuario\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('nombre');",
									"});",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set('token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"adminSuper@gmail.com\",\n    \"clave\": \"123456789Aa$\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/appeducativa-backend/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["appeducativa-backend", "login"]
						}
					}
				},
				{
					"name": "Login contrasena incorrecta",
					"event": [
